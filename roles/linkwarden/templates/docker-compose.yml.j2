---
services:
  postgres:
    container_name: linkwarden-postgres
    image: postgres:16-alpine
    environment:
      - "POSTGRES_PASSWORD={{ linkwarden_postgres_password }}"
      - "PUID={{ linkwarden_user_id }}"
      - "PGID={{ linkwarden_group_id }}"
    restart: unless-stopped
    volumes:
      - "{{ linkwarden_data_directory }}/pgdata:/var/lib/postgresql/data"
    networks:
      - bridge
    logging:
      driver: "json-file"
      options:
        max-size: "256m"
        max-file: "1"

  linkwarden:
    container_name: linkwarden
    environment:
      - "PUID={{ linkwarden_user_id }}"
      - "PGID={{ linkwarden_group_id }}"
      - "NEXTAUTH_URL=http://localhost:3000/api/v1/auth"
      - "NEXTAUTH_SECRET={{ linkwarden_nextauth_secret }}"
      - "MEILI_MASTER_KEY={{ linkwarden_meili_key }}"
      - "POSTGRES_PASSWORD={{ linkwarden_postgres_password }}"
      - "DATABASE_URL=postgresql://postgres:{{ linkwarden_postgres_password }}@postgres:5432/postgres"
      - "ANTHROPIC_API_KEY={{ linkwarden_anthropic_key }}"
      - "ANTHROPIC_MODEL={{ linkwarden_anthropic_model }}"
      - "NEXT_PUBLIC_DISABLE_REGISTRATION=true"
    restart: unless-stopped
    image: ghcr.io/linkwarden/linkwarden:latest
    volumes:
      - "{{ linkwarden_data_directory }}/data:/data/data"
    depends_on:
      - postgres
      - meilisearch
    networks:
      - bridge
    logging:
      driver: "json-file"
      options:
        max-size: "256m"
        max-file: "1"
    labels:
      - "traefik.http.routers.linkwarden.entrypoints=websecure,websecure-ext"
      - "traefik.enable={{ linkwarden_available_externally }}"
      - "traefik.http.routers.linkwarden.rule=Host(`{{ linkwarden_hostname }}.{{ ansible_nas_domain }}`)"
      - "traefik.http.routers.linkwarden.tls.domains[0].main={{ ansible_nas_domain }}"
      - "traefik.http.routers.linkwarden.tls.domains[0].sans=*.{{ ansible_nas_domain }}"
      - "traefik.http.services.linkwarden.loadbalancer.server.port=3000"
      - "flame.type=application"
      - "flame.name=linkwarden"
      - "flame.url=https://{{ linkwarden_hostname }}.{{ ansible_nas_domain }}"
      - "flame.category=Search"
      - "flame.icon=linkwarden.png"

  meilisearch:
    container_name: linkwarden-meilisearch
    image: getmeili/meilisearch:v1.12.8
    restart: unless-stopped
    environment:
      - "PUID={{ linkwarden_user_id }}"
      - "PGID={{ linkwarden_group_id }}"
      - "MEILI_MASTER_KEY={{ linkwarden_meili_key }}"
    volumes:
      - "{{ linkwarden_data_directory }}/meili_data:/meili_data"
    networks:
      - bridge
    logging:
      driver: "json-file"
      options:
        max-size: "256m"
        max-file: "1"

networks:
  bridge:
    external: true
    name: "{{ nas_bridge_network }}"
